# Copy to .env and fill in.

# ===========================================================================
# Hyperliquid (Phase 5 #38)
# ===========================================================================
# Generate a fresh wallet: `cast wallet new` (foundry).
# Faucet: https://app.hyperliquid-testnet.xyz/  (requires mainnet deposit first)
TIKR_HL_PRIVATE_KEY=0x...

# Mainnet write gate. Set to "1" to enable real order placement.
# TIKR_HL_ENABLE_MAINNET=1


# ===========================================================================
# Binance (Phase 5 #44 / #45)
# ===========================================================================
# Env vars are PRODUCT-AWARE: TIKR_BINANCE_{SPOT|FUTURES}_<SUFFIX> wins;
# falls back to plain TIKR_BINANCE_<SUFFIX> when product-specific is absent.
# Use the product-specific names when you want SEPARATE keys for spot vs
# futures (recommended — testnet.binance.vision and testnet.binancefuture.com
# are SEPARATE testnet accounts).

# --- Spot testnet ---
# Sign up at https://testnet.binance.vision (GitHub OAuth, no KYC).
# API Management → Create API → pick Ed25519 → paste keys/binance-testnet-spot-ed25519.pub
TIKR_BINANCE_SPOT_KEY_TYPE=ed25519
TIKR_BINANCE_SPOT_API_KEY=...
TIKR_BINANCE_SPOT_PRIVATE_KEY_PATH=./keys/binance-testnet-spot-ed25519.pem

# --- Futures testnet ---
# Sign up at https://testnet.binancefuture.com — separate account, separate key.
TIKR_BINANCE_FUTURES_KEY_TYPE=ed25519
TIKR_BINANCE_FUTURES_API_KEY=...
TIKR_BINANCE_FUTURES_PRIVATE_KEY_PATH=./keys/binance-testnet-futures-ed25519.pem

# Mainnet write gate (single flag, covers both spot + futures mainnet envs).
# TIKR_BINANCE_ENABLE_MAINNET=1


# ===========================================================================
# DODO (Phase 5 #40, BSC mainnet only — no testnet for LimitOrder)
# ===========================================================================
TIKR_DODO_API_KEY=...
TIKR_BSC_PRIVATE_KEY=0x...
TIKR_BSC_RPC_URL=wss://bsc-rpc.publicnode.com
TIKR_CHAINLINK_FEED=0x0567F2323251f0Aab15c8dFb1967E4e8A7D42aeE
TIKR_DODO_BASE_TOKEN=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
TIKR_DODO_QUOTE_TOKEN=0x55d398326f99059fF775485246999027B3197955
# TIKR_DODO_ENABLE_MAINNET=1
