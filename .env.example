# Copy to .env and fill in your testnet wallet private key.
# Generate one: `cast wallet new` (foundry).
# Faucet: https://app.hyperliquid-testnet.xyz/
TIKR_HL_PRIVATE_KEY=0x...

# Optional: required for any /exchange write action when env=mainnet.
# Defense-in-depth gate. Set to "1" to enable. Leave unset otherwise.
# TIKR_HL_ENABLE_MAINNET=1
