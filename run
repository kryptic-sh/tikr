#!/usr/bin/env bash
# Launch tikr app bots, one process per config.
#
# Usage:
#   ./run                            # use root config.toml
#   ./run config/foo.toml            # single config
#   ./run config/a.toml,config/b.toml  # multi-config
#
# Logs land at a private mode-0700 temp directory. Ctrl-C kills all children.

set -euo pipefail
umask 077

cd "$(dirname "$(readlink -f "$0")")"

# Source .env if present so API keys are exported to children.
if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

# Resolve config path(s).
# Usage: ./run [config1.toml[,config2.toml,...]]
# Default: root config.toml.
if [[ $# -ge 1 ]]; then
  IFS=',' read -ra CONFIGS <<< "$1"
else
  CONFIGS=("config.toml")
  echo "==> no config specified; using ${CONFIGS[0]}"
fi

for cfg in "${CONFIGS[@]}"; do
  cfg_clean="${cfg// /}"
  if [[ -z "$cfg_clean" || ! -f "$cfg_clean" ]]; then
    echo "Config not found: ${cfg_clean:-<empty>}" >&2
    exit 1
  fi
done

echo "==> building tikr (release) ..."
cargo build --release -p tikr

export RUST_LOG="${RUST_LOG:-info}"
export RUST_LOG_STYLE=always

# Private log directory. mktemp creates it atomically with an unpredictable name.
LOG_PARENT="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}"
if [[ ! -d "$LOG_PARENT" || ! -w "$LOG_PARENT" ]]; then
  LOG_PARENT="/tmp"
fi
LOG_DIR=$(mktemp -d "${LOG_PARENT%/}/tikr.XXXXXXXX")
chmod 0700 "$LOG_DIR"

declare -a PIDS=()
declare -a LOGS=()

cleanup() {
  echo
  echo "==> stopping ${#PIDS[@]} child(ren) ..."
  for pid in "${PIDS[@]}"; do
    kill -INT "$pid" 2>/dev/null || true
  done
  wait
  echo "==> logs retained at ${LOG_DIR}"
  echo "==> done."
}
trap 'cleanup; exit 130' INT TERM

for cfg in "${CONFIGS[@]}"; do
  cfg_clean="${cfg// /}"
  [[ -z "$cfg_clean" ]] && continue
  # Derive a short label from the config filename.
  label=$(basename "$cfg_clean" .toml)
  log="${LOG_DIR}/${label}.log"
  LOGS+=("$log")
  echo "==> launching ${label} (config: ${cfg_clean}, log: ${log})"
  cargo run --release -p tikr -- \
    --config "$cfg_clean" \
    --headless \
    > "${log}" 2>&1 &
  PIDS+=($!)
done

echo "==> ${#PIDS[@]} bot(s) running. Tailing logs (Ctrl-C to stop)."
echo

# Tail the explicitly-named log files (no wildcard).
tail -F "${LOGS[@]}" -n 0 2>/dev/null | grep --line-buffered -E "status|fill |WARN|ERROR" || true

cleanup 0
